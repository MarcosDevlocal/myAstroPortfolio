---
import { siteConfig } from "../config";

const path = Astro.url.pathname;
const onHome = path === "/" || path === "";

const hasProjects  = siteConfig.projects?.length  > 0;
const hasExperience = siteConfig.experience?.length > 0;
const hasEducation = siteConfig.education?.length  > 0;

const hash = (id: string) => (onHome ? `#${id}` : `/#${id}`);

const navLinks = [
  { label: "About",      href: hash("about") },
  { label: "Skills",     href: hash("skills") },
  ...(hasProjects  ? [{ label: "Projects",   href: "/projects" }] : []),
  { label: "Blog",       href: "/blog" },
  { label: "Konari",     href: hash("konari") },
  ...(hasExperience ? [{ label: "Experience", href: hash("experience") }] : []),
  ...(hasEducation  ? [{ label: "Education",  href: hash("education") }] : []),
];
---

<header
  id="site-header"
  class="site-header pointer-events-none fixed inset-x-0 top-0 z-50"
>
  {/* The header itself is transparent — only the pill floats */}
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6">

    {/* ── Logo ─────────────────────────────────────────────────────── */}
    <a
      id="site-logo"
      href="/"
      class="pointer-events-auto relative z-10 flex items-center gap-2.5 group"
      aria-label="Go home"
      data-interactive
    >
      {/* Monogram mark */}
      <span
        class="flex h-9 w-9 items-center justify-center rounded-xl border border-[var(--glass-border)] bg-[var(--glass)] text-sm font-bold tracking-tight text-[var(--text)] backdrop-blur-xl shadow-sm transition-all duration-300 group-hover:border-[var(--indigo)] group-hover:shadow-[0_0_16px_-4px_var(--glow-indigo)]"
        style="animation: logo-breathe 4s ease-in-out infinite; font-family: var(--font-mono);"
      >
        ML
      </span>
      <span class="hidden flex-col sm:flex">
        <span class="text-sm font-semibold leading-tight tracking-tight text-[var(--text)]">
          {siteConfig.name.split(" ")[0]}
        </span>
        <span class="text-[10px] font-medium uppercase tracking-[0.16em] text-[var(--text-muted)]">
          {siteConfig.title}
        </span>
      </span>
    </a>

    {/* ── Floating pill nav ────────────────────────────────────────── */}
    <nav
      id="pill-nav"
      aria-label="Primary"
      class="pointer-events-auto relative hidden items-center gap-0.5 rounded-full border border-[var(--glass-border)] bg-[color-mix(in_srgb,var(--bg-elevated)_65%,transparent)] px-2 py-1.5 backdrop-blur-2xl backdrop-saturate-150 shadow-lg md:flex"
    >
      {/* Sliding indicator — positioned via JS */}
      <span
        id="nav-indicator"
        class="nav-pill-indicator absolute top-1.5 h-[calc(100%-0.75rem)]"
        aria-hidden="true"
      ></span>

      {navLinks.map((link) => (
        <a
          href={link.href}
          data-interactive
          class="nav-link relative z-10 rounded-full px-3.5 py-1.5 text-sm font-medium text-[var(--text-muted)] transition-colors duration-200 hover:text-[var(--text)]"
        >
          {link.label}
        </a>
      ))}
    </nav>

    {/* ── Right controls ───────────────────────────────────────────── */}
    <div class="pointer-events-auto flex items-center gap-2">
      {/* Theme toggle */}
      <button
        type="button"
        data-theme-toggle
        data-interactive
        class="flex h-9 w-9 items-center justify-center rounded-full border border-[var(--glass-border)] bg-[color-mix(in_srgb,var(--bg-elevated)_65%,transparent)] text-[var(--text-muted)] shadow-sm backdrop-blur-xl transition-all duration-300 hover:border-[var(--indigo)] hover:text-[var(--text)] hover:shadow-[0_0_12px_-4px_var(--glow-indigo)]"
        aria-label="Toggle color theme"
      >
        {/* Sun (dark mode shows this) */}
        <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 18a6 6 0 1 0 0-12 6 6 0 0 0 0 12Z" stroke="currentColor" stroke-width="2"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        {/* Moon (light mode shows this) */}
        <svg class="block h-4 w-4 dark:hidden" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M21 14.5A8.5 8.5 0 0 1 9.5 3 6.5 6.5 0 1 0 21 14.5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
        </svg>
      </button>

      {/* Mobile menu toggle */}
      <button
        type="button"
        id="nav-toggle"
        data-interactive
        class="flex h-9 w-9 items-center justify-center rounded-full border border-[var(--glass-border)] bg-[color-mix(in_srgb,var(--bg-elevated)_65%,transparent)] text-[var(--text-muted)] shadow-sm backdrop-blur-xl transition-all duration-300 hover:text-[var(--text)] md:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Open menu"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>

  {/* ── Mobile nav ──────────────────────────────────────────────────── */}
  <div
    id="mobile-nav"
    class="pointer-events-auto mx-4 hidden rounded-2xl border border-[var(--glass-border)] bg-[color-mix(in_srgb,var(--bg-elevated)_82%,transparent)] px-3 py-3 backdrop-blur-2xl shadow-xl sm:mx-6"
  >
    <div class="flex flex-col gap-0.5 text-sm font-medium">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="rounded-xl px-3 py-2.5 text-[var(--text-muted)] transition-all duration-200 hover:bg-[color-mix(in_srgb,var(--indigo)_10%,transparent)] hover:text-[var(--text)]"
          data-interactive
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<style>
  @keyframes logo-breathe {
    0%, 100% { transform: scale(1); }
    50%       { transform: scale(1.03); }
  }
</style>

<script>
  // ── Scroll-triggered transform (pill drops in after 80px) ────────────────
  const header = document.getElementById("site-header") as HTMLElement;

  function syncHeader() {
    if (!header) return;
    const scrolled = window.scrollY > 80;
    header.classList.toggle("is-scrolled", scrolled);
  }
  window.addEventListener("scroll", syncHeader, { passive: true });
  syncHeader();

  // ── Sliding nav indicator ────────────────────────────────────────────────
  const indicator = document.getElementById("nav-indicator") as HTMLElement;
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>(".nav-link"));
  const pillNav = document.getElementById("pill-nav") as HTMLElement;

  function moveIndicator(el: HTMLElement) {
    if (!indicator || !pillNav) return;
    const navRect  = pillNav.getBoundingClientRect();
    const linkRect = el.getBoundingClientRect();
    indicator.style.left  = `${linkRect.left - navRect.left}px`;
    indicator.style.width = `${linkRect.width}px`;
    indicator.style.opacity = "1";
  }

  function clearIndicator() {
    if (indicator) indicator.style.opacity = "0";
  }

  links.forEach((link) => {
    link.addEventListener("mouseenter", () => moveIndicator(link));
  });
  pillNav?.addEventListener("mouseleave", clearIndicator);

  // Active link on current path
  const currentPath = window.location.pathname;
  links.forEach((link) => {
    if (link.getAttribute("href") === currentPath) {
      moveIndicator(link);
    }
  });

  // ── Mobile nav toggle ────────────────────────────────────────────────────
  const btn   = document.getElementById("nav-toggle") as HTMLButtonElement;
  const panel = document.getElementById("mobile-nav") as HTMLElement;
  btn?.addEventListener("click", () => {
    const open = panel.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", open ? "true" : "false");
    btn.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  });
  panel?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      panel.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
      btn?.setAttribute("aria-label", "Open menu");
    });
  });
</script>
