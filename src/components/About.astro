---
import { siteConfig } from "../config";
import InfiniteMarquee from "./ui/InfiniteMarquee";

const paragraphs = siteConfig.aboutMe
  .split(/\n\n+/)
  .map((p) => p.trim())
  .filter(Boolean);

// Pull skill names for the marquee
const skillNames = siteConfig.skills.map((s) =>
  typeof s === "string" ? s : s.name
);

// Words to highlight with gradient in the pull-quote
const highlightWords = ["calm", "clear", "reliable", "trust", "compassion", "technology"];
---

<section id="about" class="relative border-b border-[var(--border)] px-4 py-24 sm:px-6 sm:py-28">
  <div class="mx-auto max-w-6xl">

    {/* ── Section label ───────────────────────────────────────────────── */}
    <div class="reveal mb-14">
      <p class="font-mono-label text-[var(--indigo)]">About</p>
      <h2 class="mt-3 text-pretty text-4xl font-bold tracking-tight text-[var(--text)] sm:text-5xl md:text-6xl" style="letter-spacing: -0.03em">
        Craft, systems,
        <br />
        <span class="gradient-text">and care.</span>
      </h2>
    </div>

    {/* ── Two-column layout ────────────────────────────────────────────── */}
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-16">

      {/* Left — large typographic pull-quote */}
      <div class="reveal lg:col-span-5" data-reveal-delay="60">
        <blockquote
          class="text-pretty text-xl font-medium leading-relaxed text-[var(--text-muted)] sm:text-2xl"
          style="line-height: 1.65"
        >
          "Building backends that feel{" "}
          <span class="gradient-text font-semibold text-[var(--text)]">calm under pressure</span>
          {" "}— clear APIs, solid data models, deployments you can{" "}
          <span class="gradient-text font-semibold text-[var(--text)]">trust</span>."
        </blockquote>

        {/* Gradient animated border profile detail */}
        <div class="mt-8 gradient-border inline-flex items-center gap-3 rounded-2xl bg-[var(--bg-elevated)] px-4 py-3 shadow-md">
          <div
            class="h-10 w-10 rounded-xl flex items-center justify-center text-sm font-bold text-white shrink-0"
            style="background: linear-gradient(135deg, var(--indigo), var(--teal))"
          >
            ML
          </div>
          <div>
            <p class="text-sm font-semibold text-[var(--text)]">{siteConfig.name}</p>
            <p class="font-mono-label text-[var(--text-muted)]">{siteConfig.title}</p>
          </div>
        </div>
      </div>

      {/* Right — story paragraphs in glass panel */}
      <div
        class="reveal glass-panel space-y-5 rounded-[var(--radius-card)] p-6 sm:p-8 lg:col-span-7 transition duration-500 hover:-translate-y-0.5"
        data-reveal-delay="120"
      >
        {paragraphs.map((p, i) => (
          <p class={`text-pretty leading-[1.8] ${i === 0 ? "text-lg text-[var(--text)] font-medium" : "text-base text-[var(--text-muted)]"}`}>
            {p}
          </p>
        ))}

        {/* Location + status chips */}
        <div class="flex flex-wrap gap-2 pt-2">
          {[
            { label: "📍 Burgos → Warsaw" },
            { label: "⚡ Java · Spring Boot" },
            { label: "🌱 Open to opportunities" },
          ].map(({ label }) => (
            <span class="glass-chip rounded-full px-3.5 py-1.5 font-mono-label text-[var(--text)]">
              {label}
            </span>
          ))}
        </div>
      </div>
    </div>

    {/* ── Infinite marquee — tech ticker ───────────────────────────────── */}
    <div class="reveal mt-16" data-reveal-delay="180">
      <p class="font-mono-label mb-4 text-[var(--text-muted)]">Tech stack</p>
      <InfiniteMarquee
        client:visible
        items={skillNames}
        rows={2}
      />
    </div>
  </div>
</section>
