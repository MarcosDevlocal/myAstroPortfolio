---
import { siteConfig } from "../config";

const paragraphs = siteConfig.aboutMe
  .split(/\n\n+/)
  .map((p) => p.trim())
  .filter(Boolean);
---

<section id="about" class="relative border-b border-[var(--border)] px-4 py-20 sm:px-6 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="reveal lg:col-span-4">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent)]">About</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-[var(--text)] sm:text-4xl md:text-5xl">
          Craft, systems, and care
        </h2>
        <p class="mt-4 text-sm leading-relaxed text-[var(--text-muted)]">
          A short story about how I think — and how I build.
        </p>
      </div>

      <div
        class="reveal glass-panel space-y-6 rounded-[var(--radius-card)] p-6 sm:p-8 lg:col-span-8 motion-safe:transition motion-safe:duration-500 motion-safe:hover:-translate-y-0.5"
        style="animation-delay: 80ms"
      >
        {
          paragraphs.map((p) => (
            <p class="text-pretty text-lg leading-relaxed text-[var(--text-muted)] md:text-xl">{p}</p>
          ))
        }
      </div>
    </div>
  </div>
</section>
