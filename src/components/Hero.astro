---
import { siteConfig } from "../config";
import SplitText from "./ui/SplitText";
import BlurText from "./ui/BlurText";
import MagneticButton from "./ui/MagneticButton";
import CountUp from "./ui/CountUp";
---

<section
  id="hero"
  class="relative isolate flex min-h-[100dvh] flex-col justify-center overflow-hidden px-4 pb-24 pt-28 sm:px-6 sm:pt-32"
>
  {/* Noise texture overlay */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.025]"
    style="background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E\"); background-size: 200px 200px;"
  ></div>

  {/* Mesh gradient underlay */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(900px circle at 18% 30%, color-mix(in srgb, var(--indigo) 14%, transparent), transparent 55%), radial-gradient(700px circle at 85% 15%, color-mix(in srgb, var(--teal) 10%, transparent), transparent 50%), radial-gradient(600px circle at 55% 85%, color-mix(in srgb, var(--rose) 6%, transparent), transparent 50%)"
  ></div>

  {/* Dot grid */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background-image: radial-gradient(circle, color-mix(in srgb, var(--text) 10%, transparent) 1px, transparent 1px); background-size: 32px 32px;"
  ></div>

  <div class="mx-auto flex w-full max-w-6xl flex-col gap-14 lg:flex-row lg:items-center lg:gap-16">

    {/* ── LEFT — Hero text ──────────────────────────────────────────────── */}
    <div class="flex-1">
      {/* Availability pill */}
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--glass-border)] bg-[var(--glass)] px-4 py-1.5 backdrop-blur-xl shadow-sm">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
        </span>
        <span class="font-mono-label text-[var(--text-muted)]">Available for work · Warsaw</span>
      </div>

      {/* Eyebrow label */}
      <p class="font-mono-label mb-5 text-[var(--text-muted)]">
        Portfolio · Burgos → Warsaw → the world
      </p>

      {/* Animated name — SplitText per-character spring */}
      <SplitText
        client:load
        text={siteConfig.name}
        as="h1"
        className="text-pretty font-bold text-[var(--text)]"
        style={`font-size: clamp(3rem, 7vw, 6.5rem); letter-spacing: -0.04em; line-height: 1.05`}
      />

      {/* Animated subtitle — BlurText per-word */}
      <BlurText
        client:load
        text={`${siteConfig.title} — ${siteConfig.description}`}
        as="p"
        className="mt-5 max-w-2xl text-pretty text-lg leading-[1.75] text-[var(--text-muted)] sm:text-xl"
        delay={0.5}
      />

      {/* CTA buttons */}
      <div class="mt-9 flex flex-wrap items-center gap-3">
        <MagneticButton client:load href="/projects" variant="primary" id="hero-cta-primary">
          View projects
          <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </MagneticButton>

        <MagneticButton client:load href={`mailto:${siteConfig.social.email}`} variant="outline" id="hero-cta-contact">
          Get in touch
        </MagneticButton>

        <MagneticButton client:load href="#konari" variant="ghost" id="hero-cta-konari">
          Konari nonprofit →
        </MagneticButton>
      </div>

      {/* Social links */}
      <div class="mt-8 flex items-center gap-5">
        {siteConfig.social?.email && (
          <a
            href={`mailto:${siteConfig.social.email}`}
            aria-label="Email"
            data-interactive
            class="text-[var(--text-muted)] transition-all duration-200 hover:text-[var(--indigo)] hover:scale-110"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/><path d="M3 7l9 6 9-6"/>
            </svg>
          </a>
        )}
        {siteConfig.social?.linkedin && (
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            data-interactive
            class="text-[var(--text-muted)] transition-all duration-200 hover:text-[var(--indigo)] hover:scale-110"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8 11v5M8 8v.01M12 16v-5M16 16v-3a2 2 0 1 0-4 0M3 7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z"/>
            </svg>
          </a>
        )}
        {siteConfig.social?.github && (
          <a
            href={siteConfig.social.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            data-interactive
            class="text-[var(--text-muted)] transition-all duration-200 hover:text-[var(--indigo)] hover:scale-110"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21"/>
            </svg>
          </a>
        )}
      </div>
    </div>

    {/* ── RIGHT — Terminal card + Stats ──────────────────────────────────── */}
    <div class="relative flex w-full shrink-0 flex-col gap-4 lg:w-[400px]">

      {/* Terminal card */}
      <div
        class="reveal glass-panel overflow-hidden rounded-[var(--radius-card)] transition duration-500 hover:-translate-y-0.5"
        data-reveal-delay="200"
      >
        {/* Terminal titlebar */}
        <div class="flex items-center gap-2 border-b border-[var(--glass-border)] px-4 py-3">
          <span class="h-3 w-3 rounded-full bg-rose-400/80"></span>
          <span class="h-3 w-3 rounded-full bg-amber-400/80"></span>
          <span class="h-3 w-3 rounded-full bg-emerald-400/80"></span>
          <span class="ml-3 font-mono-label text-[var(--text-muted)]">marcos@portfolio ~ </span>
        </div>

        {/* Terminal body */}
        <div class="space-y-2 p-5 font-mono text-sm">
          <p class="text-[var(--text-muted)]"><span class="text-emerald-400">❯</span> whoami</p>
          <p class="text-[var(--text)] pl-2">Marcos Lopez Ortego</p>
          <p class="text-[var(--text)] pl-2 text-[var(--text-muted)]">Backend Developer · Nonprofit founder</p>

          <p class="pt-1 text-[var(--text-muted)]"><span class="text-emerald-400">❯</span> cat stack.json</p>
          <div class="pl-2 text-[var(--text-muted)]">
            <p><span class="text-[var(--indigo)]">{`{`}</span></p>
            <p class="pl-4"><span class="text-teal-400">"languages"</span>: <span class="text-amber-300">["Java", "C#", "Python"]</span>,</p>
            <p class="pl-4"><span class="text-teal-400">"backend"</span>: <span class="text-amber-300">["Spring Boot", ".NET"]</span>,</p>
            <p class="pl-4"><span class="text-teal-400">"platform"</span>: <span class="text-amber-300">["Docker", "Linux"]</span>,</p>
            <p class="pl-4"><span class="text-teal-400">"location"</span>: <span class="text-emerald-300">"Warsaw, PL"</span></p>
            <p><span class="text-[var(--indigo)]">{`}`}</span></p>
          </div>

          <p class="pt-1 text-[var(--text-muted)]">
            <span class="text-emerald-400">❯</span> git log --oneline -1
          </p>
          <p class="pl-2 text-[var(--text-muted)]">
            <span class="text-[var(--indigo)] font-bold" id="commit-hash">a3f9b12</span>
            {" "}<span class="text-[var(--text)]">feat: shipped v2 of this portfolio</span>
          </p>

          {/* Blinking cursor line */}
          <p class="text-[var(--text-muted)] pt-1">
            <span class="text-emerald-400">❯</span>
            <span class="ml-1 inline-block h-4 w-0.5 translate-y-0.5 bg-[var(--text)] terminal-cursor"></span>
          </p>
        </div>
      </div>

      {/* Stats card */}
      <div
        class="reveal glass-panel rounded-[var(--radius-card)] p-5 transition duration-500 hover:-translate-y-0.5"
        data-reveal-delay="280"
      >
        <p class="font-mono-label text-[var(--text-muted)]">At a glance</p>
        <div class="mt-4 grid grid-cols-3 gap-3 text-center">
          <div class="glass-chip rounded-2xl px-2 py-3">
            <p class="text-xl font-bold tabular-nums text-[var(--text)]">
              <CountUp client:visible target={3} suffix="+" />
            </p>
            <p class="mt-0.5 text-[11px] font-medium text-[var(--text-muted)]">Projects</p>
          </div>
          <div class="glass-chip rounded-2xl px-2 py-3">
            <p class="text-xl font-bold tabular-nums text-[var(--text)]">
              <CountUp client:visible target={2} suffix="+" />
            </p>
            <p class="mt-0.5 text-[11px] font-medium text-[var(--text-muted)]">Years exp.</p>
          </div>
          <div class="glass-chip rounded-2xl px-2 py-3">
            <p class="text-xl font-bold tabular-nums text-[var(--text)]">∞</p>
            <p class="mt-0.5 text-[11px] font-medium text-[var(--text-muted)]">Curiosity</p>
          </div>
        </div>

        {/* Tech stack mini-tags */}
        <div class="mt-4 flex flex-wrap gap-2">
          {["Java", "Spring Boot", ".NET", "Docker", "Linux", "SQL"].map((t) => (
            <span class="glass-chip rounded-full px-3 py-1 font-mono-label text-[var(--text)] text-[10px]">{t}</span>
          ))}
        </div>
      </div>

    </div>
  </div>

  {/* ── Scroll indicator ─────────────────────────────────────────────────── */}
  <div
    class="scroll-chevron absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5"
    aria-hidden="true"
  >
    <span class="font-mono-label text-[var(--text-muted)] opacity-60">scroll</span>
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="var(--text-muted)"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M6 9l6 6 6-6"/>
    </svg>
  </div>
</section>

<style>
  @keyframes terminal-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .terminal-cursor {
    animation: terminal-blink 1.1s step-end infinite;
  }
  @keyframes ping {
    75%, 100% { transform: scale(2); opacity: 0; }
  }
  .animate-ping {
    animation: ping 1.2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
</style>
