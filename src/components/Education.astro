---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{hasEducation && (
  <section id="education" class="border-b border-[var(--border)] px-4 py-24 sm:px-6 sm:py-28">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">

        {/* ── Left label ─────────────────────────────────────────── */}
        <div class="reveal lg:col-span-4">
          <p class="font-mono-label text-[var(--indigo)]">Education</p>
          <h2 class="mt-3 text-pretty text-4xl font-bold tracking-tight text-[var(--text)] sm:text-5xl" style="letter-spacing:-0.03em">
            Foundations
          </h2>
          <p class="mt-4 text-sm leading-relaxed text-[var(--text-muted)]">
            The academic groundwork behind the software.
          </p>
        </div>

        {/* ── Cards ──────────────────────────────────────────────── */}
        <div class="reveal space-y-5 lg:col-span-8" data-reveal-delay="80">
          {siteConfig.education.map((edu, i) => (
            <div
              class="glass-panel rounded-[var(--radius-card)] p-6 sm:p-7 transition duration-500 hover:-translate-y-0.5 hover:shadow-lg"
            >
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h3 class="text-lg font-bold tracking-tight text-[var(--text)] sm:text-xl">
                    {edu.degree}
                  </h3>
                  <p class="mt-1 text-sm font-semibold text-[var(--indigo)]">{edu.school}</p>
                </div>
                <span class="font-mono-label shrink-0 rounded-full border border-[var(--glass-border)] bg-[color-mix(in_srgb,var(--indigo)_10%,transparent)] px-3 py-1 text-[var(--text-muted)]">
                  {edu.dateRange}
                </span>
              </div>

              <ul class="mt-5 space-y-2.5">
                {edu.achievements.map((achievement) => (
                  <li class="flex gap-3 text-sm leading-relaxed text-[var(--text-muted)] sm:text-base">
                    <span
                      class="mt-[0.45em] h-1.5 w-1.5 shrink-0 rounded-full"
                      style="background: var(--teal)"
                      aria-hidden="true"
                    />
                    <span>{achievement}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>
)}
