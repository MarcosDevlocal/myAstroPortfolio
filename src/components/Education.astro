---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{hasEducation && (
  <section id="education" class="border-b border-[var(--border)] px-4 py-24 sm:px-6 sm:py-28">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">

        {/* ── Left label ─────────────────────────────────────────── */}
        <div class="reveal lg:col-span-4 flex flex-col gap-6">
          <div>
            <p class="font-mono-label text-[var(--indigo)]">Education</p>
            <h2 class="mt-3 text-pretty text-4xl font-bold tracking-tight text-[var(--text)] sm:text-5xl" style="letter-spacing:-0.03em">
              Foundations
            </h2>
            <p class="mt-4 text-sm leading-relaxed text-[var(--text-muted)]">
              The academic groundwork behind the software.
            </p>
          </div>

          {/* Education stats */}
          <div class="glass-panel rounded-2xl p-5 flex flex-col gap-4">
            <div class="flex items-center gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl" style="background: color-mix(in srgb, var(--indigo) 15%, transparent); border: 1px solid color-mix(in srgb, var(--indigo) 25%, transparent);">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--indigo)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
                </svg>
              </div>
              <div>
                <p class="font-mono-label text-[var(--text-muted)]">Degrees</p>
                <p class="text-lg font-bold text-[var(--text)]">{siteConfig.education.length} completed</p>
              </div>
            </div>

            <div class="h-px bg-[var(--border)]"></div>

            <div class="flex items-center gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl" style="background: color-mix(in srgb, var(--teal) 15%, transparent); border: 1px solid color-mix(in srgb, var(--teal) 25%, transparent);">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
              </div>
              <div>
                <p class="font-mono-label text-[var(--text-muted)]">Timeline</p>
                <p class="text-sm font-semibold text-[var(--text)]">2022 — 2026</p>
              </div>
            </div>
          </div>
        </div>

        {/* ── Cards ──────────────────────────────────────────────── */}
        <div class="reveal space-y-5 lg:col-span-8" data-reveal-delay="80">
          {siteConfig.education.map((edu, i) => (
            <div
              class="glass-panel rounded-[var(--radius-card)] p-6 sm:p-7 transition duration-500 hover:-translate-y-0.5 hover:shadow-lg group"
            >
              {/* Top row */}
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div class="flex items-start gap-4">
                  {/* Number badge */}
                  <div
                    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl font-mono text-sm font-bold text-white"
                    style={`background: linear-gradient(135deg, ${i === 0 ? "var(--indigo), var(--teal)" : "var(--teal), var(--rose)"})`}
                  >
                    {String(i + 1).padStart(2, "0")}
                  </div>
                  <div>
                    <h3 class="text-lg font-bold tracking-tight text-[var(--text)] sm:text-xl">
                      {edu.degree}
                    </h3>
                    <p class="mt-1 text-sm font-semibold" style={`color: ${i === 0 ? "var(--indigo)" : "var(--teal)"}`}>{edu.school}</p>
                  </div>
                </div>
                <span
                  class="font-mono-label shrink-0 rounded-full border border-[var(--glass-border)] bg-[color-mix(in_srgb,var(--indigo)_10%,transparent)] px-3 py-1 text-[var(--text-muted)]"
                >
                  {edu.dateRange}
                </span>
              </div>

              {/* Achievements */}
              <ul class="mt-5 space-y-2.5">
                {edu.achievements.map((achievement) => (
                  <li class="flex gap-3 text-sm leading-relaxed text-[var(--text-muted)] sm:text-base">
                    <span
                      class="mt-[0.45em] h-1.5 w-1.5 shrink-0 rounded-full"
                      style={`background: ${i === 0 ? "var(--indigo)" : "var(--teal)"}`}
                      aria-hidden="true"
                    />
                    <span>{achievement}</span>
                  </li>
                ))}
              </ul>

              {/* Bottom bar */}
              <div class="mt-5 pt-4 border-t border-[var(--glass-border)] flex items-center justify-between">
                <span class="font-mono-label text-[var(--text-muted)]">{edu.achievements.length} highlights</span>
                <div
                  class="h-0.5 rounded-full transition-all duration-700 group-hover:w-full"
                  style={`width: 2rem; background: linear-gradient(90deg, ${i === 0 ? "var(--indigo), var(--teal)" : "var(--teal), var(--rose)"})`}
                ></div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>
)}
