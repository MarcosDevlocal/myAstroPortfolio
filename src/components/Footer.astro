---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
const path = Astro.url.pathname;
const onHome = path === "/" || path === "";
const hash = (id: string) => (onHome ? `#${id}` : `/#${id}`);
---

<footer
  class="relative border-t border-[var(--border)] bg-[color-mix(in_srgb,var(--bg-elevated)_82%,transparent)] backdrop-blur-xl"
>
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="flex flex-col justify-between gap-10 md:flex-row md:items-start">
      <div class="max-w-xl space-y-4">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent)]">Contact</p>
        <h3 class="text-2xl font-semibold tracking-tight text-[var(--text)]">{siteConfig.name}</h3>
        <p class="text-sm leading-relaxed text-[var(--text-muted)]">{siteConfig.title}</p>
        <div class="flex flex-wrap gap-4">
          {
            siteConfig.social?.email && (
              <a
                href={`mailto:${siteConfig.social.email}`}
                class="text-sm font-semibold text-[color:var(--accent)] underline-offset-4 hover:underline"
              >
                Email
              </a>
            )
          }
          {
            siteConfig.social?.linkedin && (
              <a
                href={siteConfig.social.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm font-semibold text-[color:var(--accent)] underline-offset-4 hover:underline"
              >
                LinkedIn
              </a>
            )
          }
          {
            siteConfig.social?.github && (
              <a
                href={siteConfig.social.github}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm font-semibold text-[color:var(--accent)] underline-offset-4 hover:underline"
              >
                GitHub
              </a>
            )
          }
        </div>
      </div>

      <nav class="grid grid-cols-2 gap-x-10 gap-y-3 text-sm md:text-right" aria-label="Footer">
        <a class="font-medium text-[var(--text-muted)] hover:text-[var(--text)]" href={hash("about")}>About</a>
        <a class="font-medium text-[var(--text-muted)] hover:text-[var(--text)]" href={hash("skills")}>Skills</a>
        {hasProjects && <a class="font-medium text-[var(--text-muted)] hover:text-[var(--text)]" href="/projects">Projects</a>}
        <a class="font-medium text-[var(--text-muted)] hover:text-[var(--text)]" href="/blog">Blog</a>
        <a class="font-medium text-[var(--text-muted)] hover:text-[var(--text)]" href={hash("konari")}>Konari</a>
        <a class="font-medium text-[var(--text-muted)] hover:text-[var(--text)]" href={hash("journey")}>Journey</a>
        {hasExperience && (
          <a class="font-medium text-[var(--text-muted)] hover:text-[var(--text)]" href={hash("experience")}>Experience</a>
        )}
        {hasEducation && (
          <a class="font-medium text-[var(--text-muted)] hover:text-[var(--text)]" href={hash("education")}>Education</a>
        )}
      </nav>
    </div>

    <p class="mt-12 text-xs text-[var(--text-muted)]">
      © {new Date().getFullYear()} {siteConfig.name}. Crafted with Astro — light and dark, your choice.
    </p>
  </div>
</footer>
