---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
const path = Astro.url.pathname;
const onHome = path === "/" || path === "";
const hash = (id: string) => (onHome ? `#${id}` : `/#${id}`);

const links = [
  { label: "About",      href: hash("about") },
  { label: "Skills",     href: hash("skills") },
  ...(hasProjects  ? [{ label: "Projects",   href: "/projects" }] : []),
  { label: "Blog",       href: "/blog" },
  { label: "Konari",     href: hash("konari") },
  ...(hasExperience ? [{ label: "Experience", href: hash("experience") }] : []),
  ...(hasEducation  ? [{ label: "Education",  href: hash("education") }] : []),
];

const socials = [
  siteConfig.social?.email     && { label: "Email",    href: `mailto:${siteConfig.social.email}`,     icon: "email" },
  siteConfig.social?.linkedin  && { label: "LinkedIn", href: siteConfig.social.linkedin, icon: "linkedin", external: true },
  siteConfig.social?.github    && { label: "GitHub",   href: siteConfig.social.github,   icon: "github",   external: true },
].filter(Boolean) as { label: string; href: string; icon: string; external?: boolean }[];
---

<footer class="relative border-t border-[var(--border)] bg-[color-mix(in_srgb,var(--bg-elevated)_80%,transparent)] backdrop-blur-xl">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">

    {/* ── Top row ──────────────────────────────────────────────────────── */}
    <div class="flex flex-col gap-12 md:flex-row md:items-start md:justify-between">

      {/* Brand */}
      <div class="max-w-sm space-y-4">
        <div class="flex items-center gap-3">
          <span
            class="flex h-9 w-9 items-center justify-center rounded-xl text-sm font-bold text-white shrink-0"
            style="background: linear-gradient(135deg, var(--indigo), var(--teal)); font-family: var(--font-mono)"
          >
            ML
          </span>
          <div>
            <p class="text-sm font-bold text-[var(--text)]">{siteConfig.name}</p>
            <p class="font-mono-label text-[var(--text-muted)]">{siteConfig.title}</p>
          </div>
        </div>
        <p class="text-sm leading-relaxed text-[var(--text-muted)]">
          Building reliable backends and meaningful products from Burgos, Spain — currently in Warsaw.
        </p>

        {/* ── macOS dock social links ─────────────────────────── */}
        <div
          class="inline-flex items-end gap-2 rounded-full border border-[var(--glass-border)] bg-[var(--glass)] px-4 py-2.5 backdrop-blur-xl shadow-lg"
          role="list"
          aria-label="Social links"
        >
          {socials.map(({ label, href, icon, external }) => (
            <a
              href={href}
              target={external ? "_blank" : undefined}
              rel={external ? "noopener noreferrer" : undefined}
              aria-label={label}
              data-interactive
              role="listitem"
              class="group relative flex h-9 w-9 items-center justify-center rounded-full text-[var(--text-muted)] transition-all duration-300 hover:scale-125 hover:text-[var(--indigo)]"
            >
              {/* Tooltip */}
              <span class="copy-tooltip">{label}</span>

              {icon === "email" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/><path d="M3 7l9 6 9-6"/>
                </svg>
              )}
              {icon === "linkedin" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M8 11v5M8 8v.01M12 16v-5M16 16v-3a2 2 0 1 0-4 0M3 7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z"/>
                </svg>
              )}
              {icon === "github" && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21"/>
                </svg>
              )}
            </a>
          ))}

          {/* Copy email button */}
          {siteConfig.social?.email && (
            <button
              type="button"
              id="copy-email-btn"
              data-email={siteConfig.social.email}
              data-interactive
              class="group relative flex h-9 items-center gap-1.5 rounded-full border border-[var(--glass-border)] px-3 font-mono-label text-[var(--text-muted)] transition-all duration-200 hover:border-[var(--teal)] hover:text-[var(--teal)]"
              aria-label="Copy email address"
            >
              <span class="copy-tooltip" id="copy-tooltip">Copied! ✓</span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
              </svg>
              copy
            </button>
          )}
        </div>
      </div>

      {/* Nav links */}
      <nav
        class="grid grid-cols-2 gap-x-12 gap-y-2.5 text-sm md:text-right"
        aria-label="Footer navigation"
      >
        {links.map(({ label, href }) => (
          <a
            href={href}
            class="font-medium text-[var(--text-muted)] transition-colors duration-200 hover:text-[var(--text)]"
            data-interactive
          >
            {label}
          </a>
        ))}
      </nav>
    </div>

    {/* ── Bottom row ───────────────────────────────────────────────────── */}
    <div class="mt-14 flex flex-col gap-2 border-t border-[var(--border)] pt-8 sm:flex-row sm:items-center sm:justify-between">
      <p class="font-mono-label text-[var(--text-muted)]">
        © {new Date().getFullYear()} {siteConfig.name}. Crafted with Astro.
      </p>
      <p class="font-mono-label text-[var(--text-muted)]">
        Burgos, Spain · Warsaw, Poland
      </p>
    </div>
  </div>
</footer>

<script>
  // Copy-to-clipboard with tooltip feedback
  const btn = document.getElementById("copy-email-btn") as HTMLButtonElement | null;
  const tooltip = document.getElementById("copy-tooltip") as HTMLElement | null;

  btn?.addEventListener("click", async () => {
    const email = btn.dataset.email;
    if (!email || !tooltip) return;
    try {
      await navigator.clipboard.writeText(email);
      tooltip.classList.add("is-shown");
      setTimeout(() => tooltip.classList.remove("is-shown"), 2200);
    } catch {
      // Fallback: open mailto
      window.location.href = `mailto:${email}`;
    }
  });

  // Hover tooltips on social icon links
  document.querySelectorAll<HTMLAnchorElement>(".group .copy-tooltip").forEach((tip) => {
    const link = tip.closest(".group") as HTMLElement;
    if (!link) return;
    link.addEventListener("mouseenter", () => tip.classList.add("is-shown"));
    link.addEventListener("mouseleave", () => tip.classList.remove("is-shown"));
  });
</script>
