---
import { siteConfig } from "../config";

type Props = {
  includeHeading?: boolean;
};

const { includeHeading = true } = Astro.props;
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="border-b border-[var(--border)] px-4 py-20 sm:px-6 sm:py-24">
      <div class="mx-auto max-w-6xl">
        <div class:list={["grid grid-cols-1 gap-12 lg:gap-16", includeHeading && "lg:grid-cols-12"]}>
          {
            includeHeading && (
              <div class="reveal lg:col-span-4">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent)]">Work</p>
                <h2 class="mt-3 text-3xl font-semibold tracking-tight text-[var(--text)] sm:text-4xl md:text-5xl">
                  Projects
                </h2>
                <p class="mt-4 text-sm leading-relaxed text-[var(--text-muted)]">
                  Selected builds — from research platforms to integration tooling and home-lab experiments.
                </p>
                <a
                  href="/projects"
                  class="mt-6 inline-flex text-sm font-semibold text-[color:var(--accent)] underline-offset-4 hover:underline"
                >
                  Open full projects page
                </a>
              </div>
            )
          }

          <div class:list={["", includeHeading && "lg:col-span-8"]}>
            <div class="space-y-6">
              {siteConfig.projects.map((project, index) => {
                const Tag = project.link ? "a" : "div";
                const linkProps = project.link
                  ? { href: project.link, target: "_blank", rel: "noopener noreferrer" as const }
                  : {};

                return (
                  <div class="reveal group" style={`animation-delay: ${index * 70}ms`}>
                    <Tag
                      {...linkProps}
                      class:list={[
                        "glass-panel relative block overflow-hidden rounded-[var(--radius-card)] p-6 motion-safe:transition motion-safe:duration-500",
                        project.link &&
                          "motion-safe:hover:-translate-y-1 motion-safe:hover:shadow-xl",
                      ]}
                    >
                      {project.link && (
                        <span class="absolute right-5 top-5 inline-flex h-10 w-10 items-center justify-center rounded-full bg-[var(--text)] text-[var(--bg-elevated)] shadow-md transition duration-300 group-hover:opacity-90 motion-safe:group-hover:scale-110">
                          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
                          </svg>
                        </span>
                      )}

                      <div class="space-y-4">
                        <div>
                          <span class="text-xs font-semibold tracking-wider text-[color:var(--accent)]">
                            {String(index + 1).padStart(2, "0")}
                          </span>
                          <h3 class="mt-1 text-xl font-semibold tracking-tight text-[var(--text)] sm:text-2xl">
                            {project.name}
                          </h3>
                        </div>

                        <p
                          class:list={[
                            "text-base leading-relaxed text-[var(--text-muted)] sm:text-lg",
                            project.link && "pr-14",
                          ]}
                        >
                          {project.description}
                        </p>

                        {project.skills && project.skills.length > 0 && (
                          <div class="flex flex-wrap gap-2 pt-1">
                            {project.skills.map((skill) => (
                              <span class="glass-chip rounded-full px-3 py-1 text-xs font-semibold text-[var(--text)]">
                                {skill}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    </Tag>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
