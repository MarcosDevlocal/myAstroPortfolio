---
import { normalizeSkill, siteConfig } from "../config";

const groups = new Map<string, string[]>();
for (const s of siteConfig.skills) {
  const { name, category } = normalizeSkill(s);
  const list = groups.get(category) ?? [];
  list.push(name);
  groups.set(category, list);
}

const orderedCategories = Array.from(groups.keys()).sort((a, b) => {
  if (a === "General") return 1;
  if (b === "General") return -1;
  return a.localeCompare(b);
});
---

{
  siteConfig.skills.length > 0 && (
    <section id="skills" class="relative border-b border-[var(--border)] px-4 py-20 sm:px-6 sm:py-24">
      <div class="mx-auto max-w-6xl">
        <div class="reveal max-w-2xl">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent)]">Skills</p>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight text-[var(--text)] sm:text-4xl md:text-5xl">
            Easy to extend
          </h2>
          <p class="mt-4 text-sm leading-relaxed text-[var(--text-muted)] md:text-base">
            Add entries in <code class="rounded-md bg-black/[0.05] px-1.5 py-0.5 text-xs dark:bg-white/10">src/config.ts</code> — use{" "}
            <code class="rounded-md bg-black/[0.05] px-1.5 py-0.5 text-xs dark:bg-white/10">{`{ name, category }`}</code>{" "}
            to group chips automatically.
          </p>
        </div>

        <div class="mt-12 grid gap-10 md:grid-cols-2">
          {orderedCategories.map((cat, idx) => (
            <div class="reveal" style={`animation-delay: ${idx * 70}ms`}>
              <h3 class="text-sm font-semibold tracking-wide text-[var(--text)]">{cat}</h3>
              <div class="mt-4 flex flex-wrap gap-2">
                {(groups.get(cat) ?? []).map((skill) => (
                  <span class="glass-chip rounded-full px-3.5 py-1.5 text-sm font-medium text-[var(--text)] shadow-sm">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
