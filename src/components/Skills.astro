---
import { normalizeSkill, siteConfig } from "../config";
import GlowCard from "./ui/GlowCard";
import { categoryGlow } from "../lib/tokens";

const groups = new Map<string, string[]>();
for (const s of siteConfig.skills) {
  const { name, category } = normalizeSkill(s);
  const list = groups.get(category) ?? [];
  list.push(name);
  groups.set(category, list);
}

const orderedCategories = Array.from(groups.keys()).sort((a, b) => {
  if (a === "General") return 1;
  if (b === "General") return -1;
  return a.localeCompare(b);
});

const numerals = ["01", "02", "03", "04", "05", "06"];

// Category icon SVG paths (inline)
const categoryIcons: Record<string, string> = {
  "Languages":         "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
  "Backend":           "M5 12h14M12 5l7 7-7 7",
  "Data":              "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
  "Platform":          "M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18",
  "Business systems":  "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
  "General":           "M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4",
};
---

{siteConfig.skills.length > 0 && (
  <section id="skills" class="relative border-b border-[var(--border)] px-4 py-24 sm:px-6 sm:py-28">
    <div class="mx-auto max-w-6xl">

      {/* ── Section header ───────────────────────────────────────────── */}
      <div class="reveal mb-14 max-w-2xl">
        <p class="font-mono-label text-[var(--indigo)]">Skills</p>
        <h2 class="mt-3 text-pretty text-4xl font-bold tracking-tight text-[var(--text)] sm:text-5xl" style="letter-spacing:-0.03em">
          The stack I&nbsp;ship with
        </h2>
        <p class="mt-4 text-base leading-relaxed text-[var(--text-muted)]">
          Grouped by discipline. Hover a card to see the glow.
        </p>
      </div>

      {/* ── Category grid ──────────────────────────────────────────── */}
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {orderedCategories.map((cat, idx) => {
          const glowColor = categoryGlow[cat] ?? "#6366F1";
          const glowRgba  = `${glowColor}66`;
          const iconPath  = categoryIcons[cat] ?? categoryIcons["General"];
          const skills    = groups.get(cat) ?? [];
          return (
            <div class="reveal" data-reveal-delay={`${idx * 80}`}>
              <GlowCard client:visible glowColor={glowRgba} className="relative overflow-hidden p-6 h-full">
                {/* Large numeral behind content */}
                <span
                  aria-hidden="true"
                  class="pointer-events-none absolute right-4 top-2 select-none font-bold leading-none text-[var(--text)]"
                  style={`font-size: 5rem; opacity: 0.05; font-family: var(--font-mono); color: ${glowColor}`}
                >
                  {numerals[idx] ?? String(idx + 1).padStart(2, "0")}
                </span>

                {/* Category header with icon */}
                <div class="mb-4 flex items-center gap-3">
                  <div
                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg"
                    style={`background: color-mix(in srgb, ${glowColor} 15%, transparent); border: 1px solid color-mix(in srgb, ${glowColor} 30%, transparent);`}
                  >
                    <svg width="16" height="16" fill="none" stroke={glowColor} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
                      <path d={iconPath} />
                    </svg>
                  </div>
                  <div>
                    <div
                      class="h-0.5 rounded-full line-grow mb-1"
                      style={`background: ${glowColor}; max-width: 2.5rem`}
                    ></div>
                    <p class="font-mono-label" style={`color: ${glowColor}`}>{cat}</p>
                  </div>
                </div>

                {/* Skill chips */}
                <div class="flex flex-wrap gap-2">
                  {skills.map((skill) => (
                    <span
                      class="glass-chip rounded-full px-3.5 py-1.5 text-sm font-medium text-[var(--text)] shadow-sm transition-all duration-300 hover:scale-105"
                      style={`--skill-glow: ${glowColor};`}
                    >
                      {skill}
                    </span>
                  ))}
                </div>

                {/* Skill count badge */}
                <div class="mt-5 pt-4 border-t border-[var(--glass-border)] flex items-center justify-between">
                  <span class="font-mono-label text-[var(--text-muted)]">{skills.length} skills</span>
                  <div class="flex gap-1">
                    {Array.from({ length: Math.min(skills.length, 5) }).map((_, i) => (
                      <div
                        class="h-1 w-5 rounded-full"
                        style={`background: ${glowColor}; opacity: ${0.3 + (i / Math.min(skills.length, 5)) * 0.7}`}
                      ></div>
                    ))}
                  </div>
                </div>
              </GlowCard>
            </div>
          );
        })}
      </div>
    </div>
  </section>
)}
