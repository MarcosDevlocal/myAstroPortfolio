---
import { siteConfig } from "../config";

const k = siteConfig.konari;
---

<section id="konari" class="relative overflow-hidden border-b border-[var(--border)] px-4 py-20 sm:px-6 sm:py-24 motion-safe:transition-colors motion-safe:duration-700">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 opacity-60 dark:opacity-40"
    style={`background: radial-gradient(700px circle at 10% 20%, color-mix(in srgb, ${siteConfig.accentColor} 22%, transparent), transparent 60%)`}
  >
  </div>

  <div class="mx-auto max-w-6xl">
    <div
      class="grid grid-cols-1 items-start gap-12 rounded-[calc(var(--radius-card)+0.25rem)] border border-[color-mix(in_srgb,var(--accent)_14%,var(--border))] bg-[color-mix(in_srgb,var(--bg-elevated)_55%,transparent)] p-6 backdrop-blur-xl sm:p-8 lg:grid-cols-12 lg:gap-16 lg:p-10 dark:bg-[color-mix(in_srgb,var(--bg-elevated)_40%,transparent)]"
    >
      <div class="reveal lg:col-span-5">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent)]">Nonprofit</p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight text-[var(--text)] sm:text-4xl md:text-5xl">
          Konari
        </h2>
        <p class="mt-3 text-lg font-medium text-[var(--text-muted)]">{k.tagline}</p>
      </div>

      <div class="reveal space-y-8 lg:col-span-7" style="animation-delay: 90ms">
        <p class="text-pretty text-lg leading-relaxed text-[var(--text-muted)] md:text-xl">
          {k.mission}
        </p>

        <ul class="space-y-3">
          {
            k.highlights.map((line) => (
              <li class="flex gap-3 text-[var(--text)]">
                <span
                  class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full"
                  style={`background: color-mix(in srgb, ${siteConfig.accentColor} 85%, transparent)`}
                />
                <span class="text-base leading-relaxed text-[var(--text-muted)]">{line}</span>
              </li>
            ))
          }
        </ul>

        <div class="flex flex-wrap gap-3">
          {
            k.url ? (
              <a
                href={k.url}
                target="_blank"
                rel="noopener noreferrer"
                class="lift-hover inline-flex items-center justify-center rounded-full bg-[color:var(--accent)] px-5 py-2.5 text-sm font-semibold text-white shadow-md"
              >
                Visit Konari
              </a>
            ) : (
              <span class="inline-flex items-center rounded-full border border-dashed border-[var(--border)] bg-[var(--bg-elevated)] px-4 py-2 text-sm font-medium text-[var(--text-muted)]">
                Add <code class="mx-1 rounded bg-black/[0.05] px-1.5 py-0.5 text-xs dark:bg-white/10">konari.url</code> in config when your site is live
              </span>
            )
          }
          {
            siteConfig.social?.email && (
              <a
                href={`mailto:${siteConfig.social.email}?subject=${encodeURIComponent("Konari — collaboration")}`}
                class="lift-hover inline-flex items-center justify-center rounded-full border border-[var(--border)] bg-[color-mix(in_srgb,var(--bg-elevated)_70%,transparent)] px-5 py-2.5 text-sm font-semibold text-[var(--text)] shadow-sm backdrop-blur-md hover:bg-black/[0.04] dark:hover:bg-white/[0.08]"
              >
                Partner with us
              </a>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>
