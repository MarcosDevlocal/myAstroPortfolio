---
import { siteConfig } from "../config";
const k = siteConfig.konari;
---

<section
  id="konari"
  class="relative min-h-[70vh] overflow-hidden border-b border-[var(--border)] px-4 py-24 sm:px-6 sm:py-28"
>
  {/* ── Beams background — conic-gradient light rays ────────────────── */}
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    {[15, 35, 55, 75, 95, 115, 135, 155].map((angle) => (
      <div
        style={`
          position: absolute;
          top: 50%;
          left: 50%;
          width: 150%;
          height: 2px;
          transform-origin: left center;
          transform: rotate(${angle}deg) translateY(-50%);
          background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--indigo) 25%, transparent), transparent);
          filter: blur(3px);
          animation: beam-pulse ${(angle % 3) + 3}s ${(angle % 5) * 0.4}s ease-in-out infinite alternate;
        `}
      />
    ))}

    {/* Radial glow at center */}
    <div
      class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 rounded-full"
      style="width: 600px; height: 600px; background: radial-gradient(circle, color-mix(in srgb, var(--indigo) 12%, transparent) 0%, transparent 70%); filter: blur(40px);"
    />
  </div>

  <div class="mx-auto max-w-6xl">

    {/* ── Section header ───────────────────────────────────────────────── */}
    <div class="reveal mb-14 text-center">
      <p class="font-mono-label text-[var(--indigo)]">Nonprofit</p>
      <h2
        class="mt-4 text-pretty text-4xl font-bold tracking-tight text-[var(--text)] sm:text-5xl md:text-6xl"
        style="letter-spacing: -0.03em; line-height: 1.1"
      >
        Technology with a
        {" "}
        <span
          class="gradient-text-rose"
          style="display: inline-block"
        >
          heartbeat.
        </span>
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-pretty text-lg leading-relaxed text-[var(--text-muted)]">
        {k.mission}
      </p>
    </div>

    {/* ── Numbered highlight cards ─────────────────────────────────────── */}
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
      {k.highlights.map((line, i) => (
        <div class="reveal glass-panel rounded-[var(--radius-card)] p-6 transition duration-500 hover:-translate-y-1" data-reveal-delay={`${i * 80}`}>
          <span
            class="block font-mono-label"
            style="font-size: 2.5rem; opacity: 0.12; color: var(--indigo); font-family: var(--font-mono); line-height: 1; margin-bottom: 0.75rem"
            aria-hidden="true"
          >
            {String(i + 1).padStart(2, "0")}
          </span>
          <p class="text-base leading-relaxed text-[var(--text-muted)]">{line}</p>
        </div>
      ))}
    </div>

    {/* ── CTA row ──────────────────────────────────────────────────────── */}
    <div class="reveal mt-12 flex flex-wrap items-center justify-center gap-4" data-reveal-delay="240">
      {k.url ? (
        <a
          href={k.url}
          target="_blank"
          rel="noopener noreferrer"
          class="lift-hover inline-flex items-center gap-2 rounded-full bg-[var(--indigo)] px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-[var(--glow-indigo)]"
          data-interactive
        >
          Visit Konari
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      ) : (
        <span class="inline-flex items-center rounded-full border border-dashed border-[var(--border)] bg-[var(--bg-elevated)] px-5 py-2.5 font-mono-label text-[var(--text-muted)]">
          Site coming soon
        </span>
      )}

      {siteConfig.social?.email && (
        <a
          href={`mailto:${siteConfig.social.email}?subject=${encodeURIComponent("Konari — collaboration")}`}
          class="lift-hover inline-flex items-center gap-2 rounded-full border border-[var(--glass-border)] bg-[var(--glass)] px-6 py-3 text-sm font-semibold text-[var(--text)] backdrop-blur-md shadow-sm"
          data-interactive
        >
          Partner with us
        </a>
      )}
    </div>
  </div>
</section>
