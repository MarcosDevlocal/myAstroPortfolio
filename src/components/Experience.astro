---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{
  hasExperience && (
    <section id="experience" class="border-b border-[var(--border)] px-4 py-20 sm:px-6 sm:py-24">
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
          <div class="reveal lg:col-span-4">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent)]">Experience</p>
            <h2 class="mt-3 text-3xl font-semibold tracking-tight text-[var(--text)] sm:text-4xl md:text-5xl">Impact</h2>
            <p class="mt-4 text-sm leading-relaxed text-[var(--text-muted)]">
              Add roles in <code class="rounded-md bg-black/[0.05] px-1.5 py-0.5 text-xs dark:bg-white/10">experience[]</code> — newest first reads best.
            </p>
          </div>

          <div class="reveal relative lg:col-span-8" style="animation-delay: 80ms">
            <div
              aria-hidden="true"
              class="absolute left-[11px] top-3 bottom-3 hidden w-px bg-[var(--border)] md:block"
            />
            <div class="space-y-8">
              {siteConfig.experience.map((exp) => (
                <article class="relative md:pl-10">
                  <div
                    class="absolute left-1 top-2 hidden h-3 w-3 rounded-full border-2 border-[var(--bg-elevated)] md:block"
                    style={`background: color-mix(in srgb, ${siteConfig.accentColor} 85%, transparent); box-shadow: 0 0 0 6px color-mix(in srgb, ${siteConfig.accentColor} 12%, transparent)`}
                  />
                  <div class="glass-panel rounded-[var(--radius-card)] p-6 motion-safe:transition motion-safe:duration-500 motion-safe:hover:-translate-y-0.5 motion-safe:hover:shadow-lg">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                      <div>
                        <h3 class="text-lg font-semibold tracking-tight text-[var(--text)]">{exp.title}</h3>
                        <p class="mt-1 text-base font-medium text-[color:var(--accent)]">{exp.company}</p>
                      </div>
                      <p class="shrink-0 text-xs font-semibold uppercase tracking-wider text-[var(--text-muted)]">
                        {exp.dateRange}
                      </p>
                    </div>
                    <ul class="mt-5 space-y-2">
                      {exp.bullets.map((bullet) => (
                        <li class="flex gap-3 text-sm leading-relaxed text-[var(--text-muted)] sm:text-base">
                          <span
                            class="mt-2 h-1 w-1 shrink-0 rounded-full bg-[var(--text-muted)]/70"
                            aria-hidden="true"
                          />
                          <span>{bullet}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
