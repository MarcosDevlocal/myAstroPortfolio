---
import CareerJourney from "./react/CareerJourney";
---

<section id="journey" class="border-b border-[var(--border)] bg-black text-white">
  <div class="mx-auto max-w-6xl px-4 pt-16 sm:px-6">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/55">Journey</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl md:text-5xl">Orbital map</h2>
    <p class="mt-4 max-w-2xl text-pretty text-sm leading-relaxed text-white/70 md:text-base">
      A playful, spatial read on the same milestones you will see in Experience — tap nodes to explore connections (Burgos
      roots, Warsaw chapter, Konari mission).
    </p>
  </div>
  <CareerJourney client:visible />
</section>
