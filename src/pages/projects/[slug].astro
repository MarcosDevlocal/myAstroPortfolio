---
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
	const projects = await getCollection("projects");
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project }
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{project.data.name}</title>
		<style>
			body {
				margin: 0;
				padding: 40px 20px;
				background-color: #F9F9F7;
				background-image:
					linear-gradient(rgba(0,0,0,0.055) 1px, transparent 1px),
					linear-gradient(90deg, rgba(0,0,0,0.055) 1px, transparent 1px);
				background-size: 28px 28px;
				color: #0C0C0C;
				font-family: "DM Sans", sans-serif;
			}
			.wrap { max-width: 760px; margin: 0 auto; background: #FFFFFF; border: 1px solid #D8D8D4; padding: 28px; }
			.back {
				display: inline-block;
				border: 1.5px solid #0C0C0C;
				padding: 8px 14px;
				font-family: "JetBrains Mono", monospace;
				font-size: 11px;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				text-decoration: none;
				color: #0C0C0C;
				margin-bottom: 22px;
			}
			h1 { font-family: "Cormorant Garamond", serif; font-size: 54px; margin: 0 0 10px; letter-spacing: -0.02em; }
			.meta { font-family: "JetBrains Mono", monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: #7A6A48; margin-bottom: 14px; }
			p { line-height: 1.75; color: #6B6B6B; }
			a { color: inherit; }
		</style>
	</head>
	<body>
		<main class="wrap">
			<a class="back" href="/">Back to portfolio</a>
			<h1>{project.data.name}</h1>
			<div class="meta">{project.data.type}</div>
			<p>{project.data.description}</p>
			<Content />
		</main>
	</body>
</html>
