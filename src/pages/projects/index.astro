---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Projects from "../../components/Projects.astro";
import Footer from "../../components/Footer.astro";
import { siteConfig } from "../../config";
---

<BaseLayout
  title={`Projects — ${siteConfig.name}`}
  description="Selected software projects — platforms, integrations, and infrastructure experiments."
  accentColor={siteConfig.accentColor}
>
  <Header />
  <main class="pt-24 sm:pt-28">
    <div class="mx-auto max-w-6xl px-4 pb-10 sm:px-6">
      <div class="reveal max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent)]">Projects</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-[var(--text)] sm:text-5xl">Selected work</h1>
        <p class="mt-4 text-lg leading-relaxed text-[var(--text-muted)]">
          A deeper view of the same project list from the homepage — perfect for sharing in interviews or with collaborators.
        </p>
        <a
          href="/#projects"
          class="mt-6 inline-flex text-sm font-semibold text-[color:var(--accent)] underline-offset-4 hover:underline"
        >
          Back to home overview
        </a>
      </div>
    </div>
    <Projects includeHeading={false} />
  </main>
  <Footer />
</BaseLayout>
