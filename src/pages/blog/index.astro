---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../config";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = new Intl.DateTimeFormat("en", { year: "numeric", month: "short", day: "numeric" });
---

<BaseLayout
  title={`Blog — ${siteConfig.name}`}
  description="Writing on software, systems, and Konari — notes from a junior developer who cares about craft."
  accentColor={siteConfig.accentColor}
>
  <Header />
  <main class="pt-24 sm:pt-28">
    <div class="mx-auto max-w-6xl px-4 pb-16 sm:px-6">
      <div class="reveal max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent)]">Blog</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-[var(--text)] sm:text-5xl">Ideas in progress</h1>
        <p class="mt-4 text-lg leading-relaxed text-[var(--text-muted)]">
          Posts live as Markdown in <code class="rounded-md bg-black/[0.05] px-1.5 py-0.5 text-sm dark:bg-white/10">src/content/blog/</code>. Add a file, set frontmatter, deploy.
        </p>
      </div>

      <ul class="mt-14 space-y-5">
        {
          posts.map((post, i) => (
            <li class="reveal" style={`animation-delay: ${i * 60}ms`}>
              <a
                href={`/blog/${post.slug}`}
                class="group block rounded-[var(--radius-card)] border border-[var(--border)] bg-[var(--bg-elevated)] p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-lg"
              >
                <p class="text-xs font-semibold uppercase tracking-wider text-[var(--text-muted)]">
                  {fmt.format(post.data.pubDate)}
                </p>
                <h2 class="mt-2 text-xl font-semibold tracking-tight text-[var(--text)] group-hover:text-[color:var(--accent)] sm:text-2xl">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-sm leading-relaxed text-[var(--text-muted)] sm:text-base">{post.data.description}</p>
              </a>
            </li>
          ))
        }
      </ul>

      {
        posts.length === 0 && (
          <p class="mt-10 text-[var(--text-muted)]">No published posts yet — check back soon.</p>
        )
      }
    </div>
  </main>
  <Footer />
</BaseLayout>
