---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Blog</title>
		<style>
			body { margin: 0; padding: 40px 20px; background: #F9F9F7; color: #0C0C0C; font-family: "DM Sans", sans-serif; }
			.wrap { max-width: 980px; margin: 0 auto; }
			h1 { font-family: "Cormorant Garamond", serif; font-size: 64px; margin: 0 0 10px; letter-spacing: -0.02em; }
			.back { display: inline-block; margin-bottom: 20px; font-family: "JetBrains Mono", monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: #6B6B6B; }
			.grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; margin-top: 20px; }
			.card { background: #FFFFFF; border: 1px solid #D8D8D4; padding: 20px; text-decoration: none; color: inherit; }
			.title { font-family: "Cormorant Garamond", serif; font-size: 32px; margin: 0 0 8px; }
			.meta { font-family: "JetBrains Mono", monospace; font-size: 11px; color: #7A6A48; text-transform: uppercase; letter-spacing: 0.1em; }
			p { color: #6B6B6B; line-height: 1.6; }
			@media (max-width: 767px) { .grid { grid-template-columns: 1fr; } h1 { font-size: 46px; } }
		</style>
	</head>
	<body>
		<main class="wrap">
			<a href="/" class="back">Back to portfolio</a>
			<h1>Blog</h1>
			<div class="grid">
				{posts.map((post) => (
					<a class="card" href={`/blog/${post.id}`}>
						<h2 class="title">{post.data.title}</h2>
						<div class="meta">{post.data.date.toLocaleDateString("en-GB")}</div>
						<p>{post.data.excerpt}</p>
					</a>
				))}
			</div>
		</main>
	</body>
</html>
